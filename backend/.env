# backend/.env

# Ruta al binario masscan (compilado desde fuente con MSYS2)
MASSCAN_PATH=C:\tools\masscan\masscan.exe

# Ruta a nmap (solo si usas nmap_enabled=true)
NMAP_PATH=nmap

# Velocidad por defecto en pps (packets per second)
# 100-500  → red Wi-Fi casera (no saturar)
# 1000     → red local cableada (recomendado)
# 10000+   → redes de datacenter (con cuidado)
DEFAULT_SCAN_RATE=1000
MAX_SCAN_RATE=10000

# Base de datos SQLite (ruta relativa al backend/)
DATABASE_URL=sqlite:///./masscan_studio.db

# Orígenes permitidos para CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:5173